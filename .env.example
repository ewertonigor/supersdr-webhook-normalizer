# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (used by app + drizzle-kit)
# Note: docker-compose exposes Postgres on host port 5433 by default
# (to avoid clashes with a local Postgres on 5432). Inside Docker the
# app connects via the "postgres" hostname on 5432.
DATABASE_URL=postgresql://supersdr:supersdr@localhost:5433/supersdr
POSTGRES_PORT=5433

# OpenAI (REQUIRED — server fails to start if missing)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Processor
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=3
