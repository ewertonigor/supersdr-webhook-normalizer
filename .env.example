# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (used by app + drizzle-kit)
DATABASE_URL=postgresql://supersdr:supersdr@localhost:5432/supersdr

# OpenAI (REQUIRED — server fails to start if missing)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Processor
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=3
